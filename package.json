{
  "name": "personal-profile",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "start:local": "ng serve --configuration local",
    "start:dev": "ng serve --configuration dev",
    "start:test": "ng serve --configuration test",
    "start:lt": "ng serve --configuration lt",
    "start:preprod": "ng serve --configuration preprod",
    "build": "ng build",
    "build:local": "ng build --configuration local",
    "build:dev": "ng build --configuration dev",
    "build:test": "ng build --configuration test",
    "build:lt": "ng build --configuration lt",
    "build:preprod": "ng build --configuration preprod",
    "build:prod": "ng build --configuration production",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "test:ci": "ng test --no-watch --no-progress --browsers=ChromeHeadlessCI",
    "ci": "npm run lint && npm run build:prod && npm run test:ci",
    "lint": "ng lint",
    "format": "prettier --write \"src/**/*.{ts,html,scss,json}\" \"*.{json,md,js}\"",
    "format:check": "prettier --check \"src/**/*.{ts,html,scss,json}\" \"*.{json,md,js}\"",
    "audit": "npm audit",
    "audit:fix": "npm audit fix"
  },
  "private": true,
  "dependencies": {
    "@angular-architects/module-federation": "^21.2.2",
    "@angular-architects/native-federation": "^19.0.23",
    "@angular/animations": "^19.2.25",
    "@angular/cdk": "^19.2.19",
    "@angular/common": "^19.2.25",
    "@angular/compiler": "^19.2.25",
    "@angular/core": "^19.2.25",
    "@angular/forms": "^19.2.25",
    "@angular/localize": "^19.2.25",
    "@angular/material": "^19.2.19",
    "@angular/platform-browser": "^19.2.25",
    "@angular/platform-browser-dynamic": "^19.2.25",
    "@angular/router": "^19.2.25",
    "@softarc/native-federation-node": "^2.0.10",
    "es-module-shims": "^1.5.12",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^19.2.27",
    "@angular/cli": "^19.2.27",
    "@angular/compiler-cli": "^19.2.0",
    "@types/jasmine": "~5.1.0",
    "angular-eslint": "21.0.1",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "jasmine-core": "~5.6.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "prettier": "^3.8.4",
    "typescript": "~5.7.2",
    "typescript-eslint": "8.46.4"
  }
}
